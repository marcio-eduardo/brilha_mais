# --- ESTÁGIO 1: COMPILAÇÃO (BUILD) ---
FROM maven:3.9.6-eclipse-temurin-21-alpine AS builder

WORKDIR /app

# Copia apenas o pom.xml para descarregar as dependências em cache (otimiza o build)
COPY pom.xml .
RUN mvn dependency:go-offline -B

# Copia o código-fonte e compila gerando o ficheiro .jar (ignorando os testes no build do contentor)
COPY src ./src
RUN mvn clean package -DskipTests

# --- ESTÁGIO 2: EXECUÇÃO (RUNTIME) ---
FROM eclipse-temurin:21-jre-alpine

WORKDIR /app

# Adiciona um utilizador não-root para execução segura do contentor
RUN addgroup -S spring && adduser -S spring -G spring
USER spring:spring

# Copia apenas o executável gerado no estágio anterior
COPY --from=builder /app/target/*.jar app.jar

# Expõe a porta padrão do Spring Boot
EXPOSE 8080

# Define variáveis de ambiente padrão (podem ser sobrescritas no docker-compose)
ENV PORT=8080
ENV SPRING_PROFILES_ACTIVE=prod

# Comando para inicializar a aplicação
ENTRYPOINT ["java", "-jar", "app.jar"]